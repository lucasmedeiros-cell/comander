# URL del backend NestJS (opcional). El web funciona con datos demo sin backend.
# Cuando levantes el backend, descomenta y apunta aquí; /api se redirige a este host.
# NEXT_PUBLIC_API_URL=http://localhost:3000

# Fuente de datos: "mock" (demo, por defecto) o "api" (usa el backend NestJS).
NEXT_PUBLIC_DATA_SOURCE=mock
